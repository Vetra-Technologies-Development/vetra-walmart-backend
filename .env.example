# .env.example
# Copy this to .env.local and fill in your values

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Project Settings → API
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
# "snake" (default) or "camel"
SUPABASE_COLUMN_STYLE="snake"

# Optional: override table names if your schema differs
# Default prefix: walmart_
# SUPABASE_TABLE_DRIVERS="walmart_drivers"
# SUPABASE_TABLE_TRUCKS="walmart_trucks"
# SUPABASE_TABLE_LOADS="walmart_loads"
# SUPABASE_TABLE_SCENARIOS="walmart_scenarios"
# SUPABASE_TABLE_SIMULATION_RUNS="walmart_simulation_runs"
# SUPABASE_TABLE_VENDOR_SCORECARDS="walmart_vendor_scorecards"

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Optional: DAT API (for real lane rates) ───────────────────────────────────
# DAT_API_KEY=""
# DAT_API_SECRET=""

# ─── Optional: FMCSA API ───────────────────────────────────────────────────────
# FMCSA_API_KEY=""
